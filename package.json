{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Orchestrate parallel AI coding agents across any runtime, any repo, any issue tracker",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @composio/ao-web dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter '!@composio/ao-web' test",
    "test:integration": "pnpm --filter @composio/ao-integration-tests test:integration",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter '!@composio/ao-web' build && changeset publish",
    "prepare": "husky",
    "postinstall": "node scripts/rebuild-node-pty.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.55.0"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.14.0",
      "axios@>=1.0.0 <1.15.2": "1.15.2",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "esbuild@<0.25.0": "0.25.0",
      "flatted@<=3.4.1": "3.4.2",
      "follow-redirects@<=1.15.11": "1.16.0",
      "ip-address@<=10.1.0": "10.1.1",
      "langsmith@<0.6.0": "0.6.0",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.10",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "tar@<=7.5.10": "7.5.11",
      "tmp@<0.2.6": "0.2.6",
      "uuid@<11.1.1": "11.1.1",
      "uuid@>=13.0.0 <13.0.1": "13.0.1",
      "vite@>=7.0.0 <=7.3.1": "7.3.2"
    }
  }
}
